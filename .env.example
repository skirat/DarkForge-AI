# Primary key (required for TTS / Veo; text+images fall back to OpenAI if set when Gemini quota hits)
GEMINI_API_KEY=your_gemini_key_here

# Optional: OpenAI fallback when Gemini text/image quota is exhausted (never commit real keys)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3

# Optional: add more keys for parallel image/voiceover generation (avoids rate limits)
# GEMINI_API_KEY_2=...
# GEMINI_API_KEY_3=...
# GEMINI_API_KEY_4=...

# Image model: default gemini-2.5-flash-image (free tier). Use Imagen 4 on paid plans:
# IMAGE_MODEL=imagen-4.0-fast-generate-001

# Veo: try hero video for each scene. 0 = all scenes (Veo-first), 3 = only 3 hero scenes.
# HERO_SCENE_COUNT=0
# Distinct Veo clips per scene (no looping): ceil(scene_duration / HERO_VEO_CLIP_SEC), capped at MAX_HERO_PARTS_PER_SCENE.
# HERO_VEO_CLIP_SEC=8
# MAX_HERO_PARTS_PER_SCENE=8
# Veo retries: full key×model sweeps; pause between sweeps when quota hits
# VEO_MAX_ROUNDS=6
# VEO_RETRY_ROUND_WAIT_SEC=90
# VEO_KEY_COOLDOWN_SEC=15
# VEO_POLL_TIMEOUT_SEC=600
# VEO_POLL_INTERVAL_SEC=15

# Scene images: total Gemini attempts per scene before placeholder; pause after each full key cycle
# IMAGE_GEN_MAX_ATTEMPTS=48
# IMAGE_RETRY_ROUND_WAIT_SEC=60

# Veo model for hero videos. Requires supported/paid access.
# VEO_MODEL=veo-2.0-generate-001

# TTS voice (Gemini 2.5 Flash Preview TTS). Algenib = gravelly default for horror.
# TTS_VOICE=Algenib
# TTS_VOICE=Charon

# Lyria 3 story-based BGM (30s MP3, loops); requires Gemini API access; falls back to assets/music/
# LYRIA_BGM=0
# SCENE_NARRATION_GAP_SEC=0.5
# CROSSFADE_DURATION=0.45

# Optional: NanoBanana 2 API key for image fallback when Gemini/Imagen fails (then placeholder).
# Get key at https://nanobananaapi.ai/api-key
# NANOBANANA_API_KEY=your_nanobanana_key_here

# --- Remotion (motion-graphic video clips when Veo fails; requires Node + npm install in remotion_clips/) ---
# ENABLE_REMOTION=1
# REMOTION_EMBED_SCENE_IMAGE=0
# REMOTION_SKIP_OVERLAY=0
# REMOTION_RENDER_TIMEOUT_SEC=900
# REMOTION_COMPOSITION_ID=DarkForgeScene
