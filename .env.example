# Primary key (required)
GEMINI_API_KEY=your_gemini_key_here

# Optional: add more keys for parallel image/voiceover generation (avoids rate limits)
# GEMINI_API_KEY_2=...
# GEMINI_API_KEY_3=...
# GEMINI_API_KEY_4=...

# Image model: default gemini-2.5-flash-image (free tier). Use Imagen 4 on paid plans:
# IMAGE_MODEL=imagen-4.0-fast-generate-001

# Veo: try hero video for each scene. 0 = all scenes (Veo-first), 3 = only 3 hero scenes.
# HERO_SCENE_COUNT=0

# Veo model for hero videos. Requires supported/paid access.
# VEO_MODEL=veo-2.0-generate-001

# Optional: NanoBanana 2 API key for image fallback when Gemini/Imagen fails (then placeholder).
# Get key at https://nanobananaapi.ai/api-key
# NANOBANANA_API_KEY=your_nanobanana_key_here
